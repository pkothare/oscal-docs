---
import { getLatestVersion } from '../lib/metaschema';

const base = import.meta.env.BASE_URL;
const latest = await getLatestVersion();
const target = `${base}${latest}/catalog/json/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32.png`} />
    <title>OSCAL Model Reference</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>the latest OSCAL reference</a>&hellip;</p>
    <script set:html={`window.location.replace(${JSON.stringify(target)});`}></script>
  </body>
</html>
