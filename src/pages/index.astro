---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getOscalVersions, getLatestVersion } from '../lib/metaschema';

const base = import.meta.env.BASE_URL;
const OSCAL_VERSIONS = await getOscalVersions();
const LATEST_VERSION = await getLatestVersion();
---

<BaseLayout title="OSCAL Model Reference">
  <h1>OSCAL Model Reference</h1>
  <p style="color: var(--color-text-muted); margin-bottom: 2rem; max-width: 720px;">
    Dynamically generated documentation from the
    <a href="https://github.com/usnistgov/OSCAL/tree/main/src/metaschema" target="_blank" rel="noopener">OSCAL Metaschema</a>
    source files. Select a version to explore the OSCAL models.
  </p>

  <h2>Available Versions</h2>
  <div class="card-grid">
    {OSCAL_VERSIONS.slice().reverse().map(version => (
      <a href={`${base}models/${version}/`} class="card">
        <h3>
          {version}
          {version === LATEST_VERSION && <span class="version-badge latest">Latest</span>}
        </h3>
        <p>Browse all OSCAL models for version {version}</p>
      </a>
    ))}
  </div>
</BaseLayout>
---

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro</title>
	</head>
	<body>
		<h1>Astro</h1>
	</body>
</html>
