---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ModelSidebar from '../../../../components/ModelSidebar.astro';
import XmlOutline from '../../../../components/XmlOutline.astro';
import XmlDefinitionSection from '../../../../components/XmlDefinitionSection.astro';
import {
  getOscalVersions,
  MODEL_FILES,
  MODEL_DISPLAY_NAMES,
  resolveModel,
  type ResolvedModel,
} from '../../../../lib/metaschema';

export async function getStaticPaths() {
  const versions = await getOscalVersions();
  const paths: { params: { version: string; model: string } }[] = [];
  for (const version of versions) {
    for (const model of MODEL_FILES.keys()) {
      paths.push({ params: { version, model } });
    }
  }
  return paths;
}

const { version, model: modelSlug } = Astro.params;
const base = import.meta.env.BASE_URL;

let resolved: ResolvedModel;
let error: string | null = null;
try {
  resolved = await resolveModel(modelSlug!, version!);
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
  resolved = {
    name: modelSlug!,
    displayName: MODEL_DISPLAY_NAMES.get(modelSlug!) ?? modelSlug!,
    version: version!,
    definitions: [],
  };
}

const rootDef = resolved.rootDefinition;
const otherDefs = resolved.definitions.filter((d) => d !== rootDef);
const defMap = new Map(resolved.definitions.map((d) => [d.name, d]));
---

<BaseLayout
  title={`${resolved.displayName} - XML Reference - ${version}`}
  version={version}
  model={modelSlug}
  format="xml"
>
  <div class="sidebar-layout">
    <ModelSidebar
      base={base}
      version={version!}
      modelSlug={modelSlug!}
      format="xml"
      definitions={otherDefs}
    />

    <div class="content">
      <h1>{resolved.displayName}</h1>

      {
        error && (
          <div
            class="def-remarks"
            style="border-left-color: var(--brand-secondary); margin-bottom: 1rem;"
          >
            Error loading metaschema: {error}
          </div>
        )
      }

      {rootDef && rootDef.modelItems.length > 0 && <XmlOutline rootDef={rootDef} defMap={defMap} />}

      {rootDef && <XmlDefinitionSection def={rootDef} defMap={defMap} asRoot />}

      <h2>Element Definitions ({otherDefs.length})</h2>
      {otherDefs.map((def) => <XmlDefinitionSection def={def} defMap={defMap} />)}
    </div>
  </div>
</BaseLayout>
