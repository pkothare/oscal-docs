---
export interface Props {
  title: string;
  version?: string;
  model?: string;
}

const { title, version, model } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | OSCAL Foundation Docs</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body>
    <header>
      <nav class="top-nav">
        <a href={base} class="logo">OSCAL Foundation</a>
        <span class="nav-subtitle">Model Reference Documentation</span>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Generated from <a href="https://github.com/usnistgov/OSCAL" target="_blank" rel="noopener">OSCAL Metaschema</a> sources. An <a href="https://oscalfoundation.org/" target="_blank" rel="noopener">OSCAL Foundation</a> project.</p>
    </footer>
  </body>
</html>

<style is:global>
  /* OSCAL Foundation Color Scheme */
  :root {
    --color-bg-dark: #0b1a2e;
    --color-bg-darker: #071222;
    --color-bg-card: #0f2340;
    --color-bg-card-hover: #153058;
    --color-accent: #00b4d8;
    --color-accent-light: #48cae4;
    --color-accent-dim: #0096b7;
    --color-text: #e0e7ef;
    --color-text-muted: #8899aa;
    --color-text-heading: #ffffff;
    --color-border: #1a3355;
    --color-success: #2ecc71;
    --color-warning: #f39c12;
    --color-type-assembly: #48cae4;
    --color-type-field: #2ecc71;
    --color-type-flag: #f39c12;
    --color-code-bg: #0a1628;
    --header-height: 60px;
    --footer-height: 72px;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    color-scheme: dark;
  }

  body {
    background: var(--color-bg-dark);
    color: var(--color-text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--color-accent-light);
  }

  header {
    background: var(--color-bg-darker);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .top-nav {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-heading);
    letter-spacing: -0.02em;
  }

  .logo:hover {
    color: var(--color-accent);
  }

  .nav-subtitle {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    flex: 1;
    width: 100%;
  }

  footer {
    background: var(--color-bg-darker);
    border-top: 1px solid var(--color-border);
    padding: 1.5rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-top: auto;
    position: sticky;
    bottom: 0;
    z-index: 100;
  }

  h1 {
    color: var(--color-text-heading);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  h2 {
    color: var(--color-text-heading);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  h3 {
    color: var(--color-text-heading);
    font-size: 1.15rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }

  code {
    background: var(--color-code-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--color-accent-light);
    border: 1px solid var(--color-border);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb .sep {
    color: var(--color-border);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    transition: all 0.2s;
    display: block;
  }

  .card:hover {
    background: var(--color-bg-card-hover);
    border-color: var(--color-accent-dim);
    transform: translateY(-1px);
  }

  .card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  .card p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .version-badge {
    display: inline-block;
    background: var(--color-accent-dim);
    color: white;
    padding: 0.2em 0.6em;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .version-badge.latest {
    background: var(--color-success);
  }

  .type-badge {
    display: inline-block;
    padding: 0.15em 0.5em;
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .type-badge.assembly {
    background: rgba(72, 202, 228, 0.15);
    color: var(--color-type-assembly);
    border: 1px solid rgba(72, 202, 228, 0.3);
  }

  .type-badge.field {
    background: rgba(46, 204, 113, 0.15);
    color: var(--color-type-field);
    border: 1px solid rgba(46, 204, 113, 0.3);
  }

  .type-badge.flag {
    background: rgba(243, 156, 18, 0.15);
    color: var(--color-type-flag);
    border: 1px solid rgba(243, 156, 18, 0.3);
  }

  .def-section {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    margin: 1rem 0;
  }

  .def-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .def-name {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text-heading);
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
  }

  .def-description {
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .def-remarks {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    padding: 0.75rem;
    background: var(--color-bg-darker);
    border-radius: 4px;
    border-left: 3px solid var(--color-accent-dim);
    margin-top: 0.75rem;
  }

  .property-table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }

  .property-table th {
    text-align: left;
    padding: 0.6rem 0.75rem;
    background: var(--color-bg-darker);
    color: var(--color-text-muted);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--color-border);
  }

  .property-table td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .property-table tr:last-child td {
    border-bottom: none;
  }

  .property-table tr:hover td {
    background: rgba(255, 255, 255, 0.02);
  }

  .constraint-list {
    list-style: none;
    margin: 0.5rem 0;
  }

  .constraint-list > li {
    padding: 0.5rem 0.75rem;
    background: var(--color-bg-darker);
    border-radius: 4px;
    margin: 0.25rem 0;
    font-size: 0.875rem;
    border-left: 3px solid var(--color-warning);
  }

  .constraint-type {
    font-weight: 600;
    color: var(--color-warning);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    margin-right: 0.5rem;
  }

  .enum-list {
    list-style: none;
    margin: 0.5rem 0 0;
    padding-left: 1rem;
  }

  .enum-list li {
    padding: 0.35rem 0;
    font-size: 0.875rem;
  }

  .enum-value {
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: var(--color-accent-light);
    font-weight: 500;
  }

  .cardinality {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-family: monospace;
  }

  .format-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .format-tab {
    padding: 0.4rem 1rem;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .format-tab.active {
    background: var(--color-accent-dim);
    border-color: var(--color-accent);
    color: white;
  }

  .sidebar-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2rem;
  }

  .sidebar-layout > .content {
    grid-column: 2;
  }

  .sidebar {
    position: fixed;
    top: var(--header-height, 60px);
    bottom: var(--footer-height, 60px);
    width: 260px;
    overflow-y: auto;
    padding-right: 1rem;
  }

  .sidebar-section {
    margin-bottom: 1.5rem;
  }

  .sidebar-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar-link {
    display: block;
    padding: 0.25rem 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    border-radius: 4px;
    margin: 0.1rem 0;
  }

  .sidebar-link:hover, .sidebar-link.active {
    background: var(--color-bg-card);
    color: var(--color-accent);
  }

  .version-select {
    width: 100%;
    padding: 0.4rem 0.6rem;
    background: var(--color-bg-card);
    color: var(--color-text);
    border: 1px solid var(--color-border, #1a3050);
    border-radius: 4px;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
  }
  .version-select:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .sidebar-layout {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
      max-height: none;
    }
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
