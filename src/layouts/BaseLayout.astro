---
import { getOscalVersions, getLatestVersion } from "../lib/metaschema";
import "../styles/global.css";

export interface Props {
  title: string;
  version?: string;
  model?: string;
  format?: "json" | "xml";
}

const { title, version, model, format } = Astro.props;
const base = import.meta.env.BASE_URL;

const versions = version ? await getOscalVersions() : [];
const latest = version ? await getLatestVersion() : "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | OSCAL Foundation Docs</title>
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="512x512" href={`${base}favicon-512.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}favicon-180.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;500&family=Roboto:wght@300;400;500;700&display=swap"
    />
  </head>
  <body>
    <header>
      <nav class="top-nav">
        <a href={base} class="logo">
          <img src={`${base}logo.png`} alt="OSCAL Foundation" />
        </a>
        <span class="nav-subtitle">Model Reference Documentation</span>
        {version && model && format && (
          <div class="header-controls">
            <div class="format-toggle">
              <a
                href={`${base}${version}/${model}/json/`}
                class:list={["format-toggle-btn", format === "json" && "active"]}
              >JSON</a>
              <a
                href={`${base}${version}/${model}/xml/`}
                class:list={["format-toggle-btn", format === "xml" && "active"]}
              >XML</a>
            </div>
            <select
              class="version-select header-version-select"
              onchange="if(this.value)window.location.href=this.value"
              aria-label="OSCAL version"
            >
              {versions
                .slice()
                .reverse()
                .map((v) => (
                  <option
                    value={`${base}${v}/${model}/${format}/`}
                    selected={v === version}
                  >
                    {v}
                    {v === latest ? " (latest)" : ""}
                  </option>
                ))}
            </select>
          </div>
        )}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Generated from <a href="https://github.com/usnistgov/OSCAL" target="_blank" rel="noopener">OSCAL Metaschema</a> sources. An <a href="https://oscalfoundation.org/" target="_blank" rel="noopener">OSCAL Foundation</a> project.</p>
    </footer>
    <script is:inline>
      (function () {
        function updateFragmentActive() {
          var hash = window.location.hash;
          document.querySelectorAll('.sidebar-link.fragment-active').forEach(function (el) {
            el.classList.remove('fragment-active');
          });
          if (!hash || hash.length < 2) return;
          document.querySelectorAll('.sidebar-link').forEach(function (el) {
            var href = el.getAttribute('href') || '';
            var idx = href.indexOf('#');
            if (idx >= 0 && href.slice(idx) === hash) {
              el.classList.add('fragment-active');
            }
          });
        }
        window.addEventListener('hashchange', updateFragmentActive);
        document.addEventListener('DOMContentLoaded', updateFragmentActive);
        updateFragmentActive();
      })();
    </script>
  </body>
</html>

<style is:global>
  /* OSCAL Foundation brand palette */
  :root {
    --brand-primary: #4e79d8;
    --brand-secondary: #223152;
    --brand-text: #121212;
    --brand-accent: #d2dcf3;

    --brand-primary-dark: #3a5fb5;
    --brand-primary-light: #7a96e3;
    --brand-accent-soft: #eaf0fb;
    --brand-secondary-soft: #3a4a73;

    --color-bg-dark: #ffffff;
    --color-bg-darker: var(--brand-secondary);
    --color-bg-card: #ffffff;
    --color-bg-card-hover: var(--brand-accent-soft);
    --color-accent: var(--brand-primary);
    --color-accent-light: var(--brand-primary-light);
    --color-accent-dim: var(--brand-primary-dark);
    --color-text: var(--brand-text);
    --color-text-muted: #4a5568;
    --color-text-heading: var(--brand-secondary);
    --color-border: var(--brand-accent);
    --color-success: #2f7d4a;
    --color-warning: #b65d12;
    --color-type-assembly: var(--brand-primary);
    --color-type-field: var(--brand-secondary);
    --color-type-flag: var(--brand-primary-light);
    --color-code-bg: var(--brand-accent-soft);
    --header-height: 60px;
    --footer-height: 72px;

    --font-sans: "Roboto", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-mono: "Roboto Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: auto;
    color-scheme: light;
  }

  body {
    background: var(--color-bg-dark);
    color: var(--color-text);
    font-family: var(--font-sans);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--color-accent-light);
  }

  header {
    background: var(--brand-accent-soft);
    color: var(--color-text);
    border-bottom: 1px solid var(--brand-accent);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  header a {
    color: var(--color-text-heading);
  }
  header a:hover {
    color: var(--brand-primary);
  }

  .top-nav {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .header-controls {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .format-toggle {
    display: inline-flex;
    border: 1px solid var(--brand-accent);
    border-radius: 4px;
    overflow: hidden;
    background: #ffffff;
    flex-shrink: 0;
  }

  .format-toggle-btn {
    flex: 0 0 auto;
    display: inline-block;
    padding: 0.35rem 0.75rem;
    min-width: 3.5rem;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.2;
    white-space: nowrap;
  }

  .format-toggle-btn + .format-toggle-btn {
    border-left: 1px solid var(--brand-accent);
  }

  .format-toggle-btn:hover {
    background: var(--brand-accent-soft);
    color: var(--brand-primary);
  }

  .format-toggle-btn.active {
    background: var(--brand-primary);
    color: #ffffff;
  }

  .header-version-select {
    width: auto;
    min-width: 8rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
  }

  .logo img {
    display: block;
    height: 32px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }

  .logo:hover img {
    opacity: 0.85;
  }

  .nav-subtitle {
    color: var(--brand-secondary);
    font-size: 0.875rem;
  }

  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    flex: 1;
    width: 100%;
  }

  footer {
    background: var(--brand-accent-soft);
    color: var(--color-text-muted);
    border-top: 1px solid var(--brand-accent);
    padding: 1.5rem;
    text-align: center;
    font-size: 0.875rem;
    margin-top: auto;
    position: sticky;
    bottom: 0;
    z-index: 100;
  }

  footer a {
    color: var(--brand-primary);
  }
  footer a:hover {
    color: var(--brand-primary-dark);
  }

  h1 {
    color: var(--color-text-heading);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  h2 {
    color: var(--color-text-heading);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  h3 {
    color: var(--color-text-heading);
    font-size: 1.15rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }

  code {
    background: var(--color-code-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--color-accent-light);
    border: 1px solid var(--color-border);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb .sep {
    color: var(--color-border);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    transition: all 0.2s;
    display: block;
  }

  .card:hover {
    background: var(--color-bg-card-hover);
    border-color: var(--color-accent-dim);
    transform: translateY(-1px);
  }

  .card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  .card p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .version-badge {
    display: inline-block;
    background: var(--color-accent-dim);
    color: white;
    padding: 0.2em 0.6em;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .version-badge.latest {
    background: var(--color-success);
  }

  .type-badge {
    display: inline-block;
    padding: 0.15em 0.5em;
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .type-badge.assembly {
    background: var(--brand-accent-soft);
    color: var(--color-type-assembly);
    border: 1px solid var(--brand-accent);
  }

  .type-badge.field {
    background: var(--brand-accent-soft);
    color: var(--color-type-field);
    border: 1px solid var(--brand-accent);
  }

  .type-badge.flag {
    background: var(--brand-accent-soft);
    color: var(--color-type-flag);
    border: 1px solid var(--brand-accent);
  }

  .def-section {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    margin: 1rem 0;
  }

  .def-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .def-name {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text-heading);
    font-family: var(--font-mono);
  }

  .def-description {
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .def-remarks {
    color: var(--color-text);
    font-size: 0.875rem;
    padding: 0.75rem;
    background: var(--brand-accent-soft);
    border-radius: 4px;
    border-left: 3px solid var(--color-accent);
    margin-top: 0.75rem;
  }

  .property-table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }

  .property-table th {
    text-align: left;
    padding: 0.6rem 0.75rem;
    background: var(--brand-accent-soft);
    color: var(--color-text-heading);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--color-border);
  }

  .property-table td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .property-table tr:last-child td {
    border-bottom: none;
  }

  .property-table tr:hover td {
    background: var(--brand-accent-soft);
  }

  .constraint-list {
    list-style: none;
    margin: 0.5rem 0;
  }

  .constraint-list > li {
    padding: 0.5rem 0.75rem;
    background: var(--brand-accent-soft);
    border-radius: 4px;
    margin: 0.25rem 0;
    font-size: 0.875rem;
    border-left: 3px solid var(--color-warning);
  }

  .constraint-type {
    font-weight: 600;
    color: var(--color-warning);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    margin-right: 0.5rem;
  }

  .enum-list {
    list-style: none;
    margin: 0.5rem 0 0;
    padding-left: 1rem;
  }

  .enum-list li {
    padding: 0.35rem 0;
    font-size: 0.875rem;
  }

  .enum-value {
    font-family: var(--font-mono);
    color: var(--color-accent-dim);
    font-weight: 500;
  }

  .cardinality {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }

  .format-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .format-tab {
    padding: 0.4rem 1rem;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .format-tab.active {
    background: var(--color-accent-dim);
    border-color: var(--color-accent);
    color: white;
  }

  .sidebar-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2rem;
  }

  .sidebar-layout > .content {
    grid-column: 2;
  }

  .sidebar {
    position: fixed;
    top: var(--header-height, 60px);
    bottom: var(--footer-height, 60px);
    width: 260px;
    overflow-y: auto;
    padding-right: 1rem;
  }

  .sidebar-section {
    margin-bottom: 1.5rem;
    margin-top: 1.5rem;
  }

  .sidebar-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar-link {
    display: block;
    padding: 0.25rem 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    border-radius: 4px;
    margin: 0.1rem 0;
  }

  .sidebar-link:hover {
    background: var(--color-bg-card);
    color: var(--color-accent);
  }

  .sidebar-link.active,
  .sidebar-link.fragment-active {
    background: var(--brand-accent);
    color: var(--brand-secondary);
  }

  .sidebar-link.active:hover,
  .sidebar-link.fragment-active:hover {
    background: var(--brand-accent);
    color: var(--brand-secondary);
  }

  .version-select {
    width: 100%;
    padding: 0.4rem 0.6rem;
    background: var(--color-bg-card);
    color: var(--color-text);
    border: 1px solid var(--color-border, #1a3050);
    border-radius: 4px;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
  }
  .version-select:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .sidebar-layout {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
      max-height: none;
    }
    .card-grid {
      grid-template-columns: 1fr;
    }
  }

  .outline-section {
    margin-bottom: 2rem;
  }
  .outline-intro {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: 0.25rem 0 0.75rem;
  }
  .outline-block {
    background: var(--color-bg-card, #fff);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    font-family: var(--font-mono, "Roboto Mono", monospace);
    font-size: 0.85rem;
    line-height: 1.6;
    overflow-x: auto;
  }
  .outline-block code {
    background: var(--brand-accent-soft, transparent);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: inherit;
    color: var(--brand-primary-dark, var(--brand-primary));
  }
  .outline-block a {
    color: var(--brand-primary-dark, var(--brand-primary));
    text-decoration: none;
  }
  .outline-block a code {
    transition: background 0.1s ease;
  }
  .outline-block a:hover code {
    background: var(--brand-accent, var(--brand-accent-soft));
    text-decoration: none;
  }
  .outline-card {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }
  .outline-node > summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    position: relative;
    padding-left: 1.1rem;
  }
  .outline-node > summary::-webkit-details-marker {
    display: none;
  }
  .outline-node > summary::before {
    content: "▶";
    position: absolute;
    left: 0;
    top: 0;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    transition: transform 0.1s ease;
    transform-origin: 40% 55%;
  }
  .outline-node[open] > summary::before {
    transform: rotate(90deg);
  }
  .outline-children {
    padding-left: 1.5rem;
    border-left: 1px dotted var(--color-border);
    margin-left: 0.35rem;
  }
  .outline-node,
  .outline-leaf {
    margin: 0.25rem 0;
  }
  .outline-close {
    padding-left: 1.1rem;
    margin-top: 0.25rem;
  }
  .outline-leaf {
    padding-left: 1.1rem;
  }
</style>
