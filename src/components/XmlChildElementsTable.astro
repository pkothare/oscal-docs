---
import type { ModelItem, MetaschemaDefinition } from '../lib/metaschema';

interface Props {
  items: ModelItem[];
  defMap: Map<string, MetaschemaDefinition>;
}

const { items, defMap } = Astro.props;

function cardinality(item: ModelItem): string {
  const min = item.minOccurs ?? 0;
  const max = item.maxOccurs;
  if (max === 'unbounded') return `[${min} to ∞]`;
  if (max !== undefined) return `[${min} to ${max}]`;
  if (min === 1) return '[1]';
  return '[0 or 1]';
}
---

<div>
  <h3>Child Elements ({items.length})</h3>
  <div class="table-scroll">
    <table class="property-table">
      <thead>
        <tr>
          <th>Element</th>
          <th>Type</th>
          <th>Cardinality</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        {
          items.map((item) => {
            const tag = item.ref || item.name || '';
            const refDef = item.ref ? defMap.get(item.ref) : null;
            const hasDef = defMap.has(tag);
            return (
              <tr id={!hasDef ? tag : undefined}>
                <td>
                  {hasDef ? (
                    <a href={`#${tag}`}>
                      <code>&lt;{tag}&gt;</code>
                    </a>
                  ) : (
                    <code>&lt;{tag}&gt;</code>
                  )}
                </td>
                <td>
                  <span class:list={['type-badge', item.type]}>{item.type}</span>
                </td>
                <td>
                  <span class="cardinality">{cardinality(item)}</span>
                </td>
                <td set:html={refDef?.description || item.description || ''} />
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</div>
