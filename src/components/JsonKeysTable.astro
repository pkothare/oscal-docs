---
import type { FieldDef, ModelItem, MetaschemaDefinition } from '../lib/metaschema';

interface Props {
  flags: FieldDef[];
  items: ModelItem[];
  defMap: Map<string, MetaschemaDefinition>;
}

const { flags, items, defMap } = Astro.props;

function jsonName(item: ModelItem): string {
  return item.groupAs || item.ref || item.name || '';
}
function typeName(item: ModelItem): string {
  return item.ref || item.name || '';
}
function cardinality(item: ModelItem): string {
  const min = item.minOccurs ?? 0;
  const max = item.maxOccurs;
  if (max === 'unbounded') return `[${min} to ∞]`;
  if (max !== undefined) return `[${min} to ${max}]`;
  if (min === 1) return '[1]';
  return '[0 or 1]';
}

const total = flags.length + items.length;
---

<div>
  <h3>Keys ({total})</h3>
  <div class="table-scroll">
    <table class="property-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Definition</th>
          <th>Cardinality</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        {
          flags.map((flag) => (
            <tr>
              <td>
                <code>{flag.name}</code>
              </td>
              <td>{flag.asType || 'string'}</td>
              <td>
                <span class="cardinality">{flag.required ? '[1]' : '[0 or 1]'}</span>
              </td>
              <td set:html={flag.description} />
            </tr>
          ))
        }
        {
          items.map((item) => {
            const refDef = item.ref ? defMap.get(item.ref) : null;
            const jn = jsonName(item);
            const tn = typeName(item);
            const defLabel = refDef?.formalName || tn;
            const hasDef = defMap.has(tn);
            return (
              <tr id={!hasDef ? jn : undefined}>
                <td>
                  <code>{jn}</code>
                </td>
                <td>{hasDef ? <a href={`#${tn}`}>{defLabel}</a> : defLabel}</td>
                <td>
                  <span class="cardinality">{cardinality(item)}</span>
                </td>
                <td set:html={refDef?.description || item.description || ''} />
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</div>
