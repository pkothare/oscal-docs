---
import type { FieldDef } from '../lib/metaschema';

interface Props {
  flag: FieldDef;
  isLast?: boolean;
}

const { flag, isLast } = Astro.props;
const tail = isLast ? '' : ',';
const type = flag.asType || 'string';
---

<div class="outline-leaf">
  <code>{flag.name}</code>{' '}
  <span class="outline-card">{flag.required ? '[1]' : '[0 or 1]'}</span>: {type}
  {tail}
</div>
